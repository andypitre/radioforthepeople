# Production secrets for the Nexlayer deploy.
# Copy to deploy/.env.production (gitignored) and fill in real values.
# Generate long random values for every field — rotate if any of these leak.
#
#   # Generate a signing secret and DB passwords:
#   openssl rand -base64 32
#
# All fields are required. deploy/deploy.sh will fail loudly if any are missing.

# Nexlayer registry username (same one appears in your pushed image tags)
NEXLAYER_USER=andypitre

# Built image references — updated by deploy/build-images.sh after push
APP_IMAGE=registry.nexlayer.io/nexlayer-mcp/andypitre/rftp-app:v1
SERVER_IMAGE=registry.nexlayer.io/nexlayer-mcp/andypitre/rftp-server:v1
DB_IMAGE=registry.nexlayer.io/nexlayer-mcp/andypitre/rftp-db:v1

# Postgres admin role (rftp) — owns migrations
POSTGRES_PASSWORD=

# Postgres app role (rftp_app) — non-superuser, runtime connections, RLS enforces
RFTP_APP_PASSWORD=

# HMAC key for signed session cookies. NEVER reuse your local .env value.
SESSION_SECRET=

# Google OAuth (reused from local dev for now).
# Remember to add https://radioforthepeople.org/auth/google/callback
# as an authorized redirect URI in the Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
