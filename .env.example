# Admin DB URL (superuser) — used for migrations only
DATABASE_URL=postgres://rftp:rftp@localhost:5432/radioforthepeople

# App DB URL (non-superuser) — used by the app at runtime; RLS enforces
DATABASE_URL_APP=postgres://rftp_app:rftp_app@localhost:5432/radioforthepeople

APP_PORT=1077
SERVER_PORT=1078

VITE_WS_URL=ws://localhost:1078

# Google OAuth — create at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:1077/auth/google/callback

# Session cookie signing — generate with: openssl rand -base64 32
SESSION_SECRET=
